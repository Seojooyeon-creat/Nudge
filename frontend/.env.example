# Supabase (Project Settings → API). The anon key is safe to ship to the client.
EXPO_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Nudge backend base URL.
# Use your machine's LAN IP (e.g. http://192.168.1.20:8000) when testing on a
# physical device — "localhost" points at the phone, not your computer.
EXPO_PUBLIC_API_URL=http://localhost:8000
